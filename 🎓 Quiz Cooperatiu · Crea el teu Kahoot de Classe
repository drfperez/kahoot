.upload-btn:hover { background: rgb(35, 139, 126); box-shadow: rgba(42, 157, 143, 0.45) 0px 6px 20px; }

.file-name { display: block; margin-top: 8px; font-size: 0.85rem; color: var(--text-light); word-break: break-all; }

.file-input-hidden { position: absolute; width: 1px; height: 1px; padding: 0px; margin: -1px; overflow: hidden; clip: rect(0px, 0px, 0px, 0px); border: 0px; }

.shuffle-notice { background: rgb(255, 243, 205); border: 1px solid rgb(255, 238, 186); border-radius: 8px; padding: 8px 14px; margin-bottom: 10px; text-align: center; font-size: 0.85rem; font-weight: 500; color: rgb(133, 100, 4); }

@media (max-width: 600px) {
  .main-container { padding: 12px 10px 30px; gap: 14px; }
  .card { padding: 18px 14px; }
  .options-grid-edit { grid-template-columns: 1fr; }
  .answers-grid { gap: 10px; min-height: 240px; }
  .answer-btn { font-size: 1rem; padding: 14px 10px; }
  .question-display { font-size: 1.2rem; padding: 24px 16px; }
  .top-bar { font-size: 0.9rem; padding: 10px 14px; flex-direction: column; align-items: center; text-align: center; }
  button { font-size: 0.85rem; padding: 10px 16px; }
  .upload-btn { max-width: 260px; font-size: 0.9rem; padding: 12px 20px; }
}
